{
  "name": "@riveo/eslint-config",
  "version": "0.2.0",
  "description": "Opinionated flat ESLint config for TypeScript-first projects with JavaScript and frameworks support.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "pretest": "pnpm run build",
    "test": "node --test",
    "check": "pnpm run '/^check:.+/'",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "format": "prettier --write .",
    "codegen:rules": "node scripts/update-generated-rules.ts",
    "prebuild": "rimraf dist/ && pnpm run codegen:rules",
    "build": "tsc --project ./tsconfig.build.json",
    "prepublishOnly": "pnpm run check && pnpm run build && pnpm --config.enable-pre-post-scripts=false run test"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "flat-config",
    "typescript",
    "astro",
    "javascript"
  ],
  "author": "Piotr Rzeczkowski <pr@riveolabs.com>",
  "homepage": "https://github.com/riveo/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riveo/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/riveo/eslint-config/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@eslint/config-helpers": "^0.4.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": "^9.30.0"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.59.0"
  }
}

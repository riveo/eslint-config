{
  "name": "@riveo/eslint-config",
  "version": "0.1.0",
  "description": "Opinionated flat ESLint config for TypeScript-first projects with JavaScript and frameworks support.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "pretest": "pnpm run build",
    "test": "node --test",
    "check": "pnpm run '/^check:.+/'",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "format": "prettier --write .",
    "codegen:rules": "node scripts/update-generated-rules.ts",
    "prebuild": "rimraf dist/ && pnpm run codegen:rules",
    "build": "tsc --project ./tsconfig.build.json"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "flat-config",
    "typescript",
    "astro",
    "javascript"
  ],
  "author": "Piotr Rzeczkowski <pr@riveolabs.com>",
  "homepage": "https://github.com/riveo/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riveo/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/riveo/eslint-config/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@eslint/config-helpers": "^0.5.4",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "eslint": "^10.2.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "eslint": "^9.22.0"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript-eslint": "^8.58.0"
  },
  "optionalDependencies": {
    "eslint-plugin-astro": "^1.6.0"
  }
}
